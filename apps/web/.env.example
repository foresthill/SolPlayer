# SolPlayer 環境変数テンプレート
#
# ローカル開発: このファイルを .env.local にコピーして実際の値を入れる
#   cp .env.example .env.local
# 本番(Vercel): Settings → Environment Variables に同じ変数を登録する
# （.env.local はgitignore済み。実際の値は絶対にコミットしないこと）

# --- フェーズ2: アカウント同期（Googleログイン + DB） ---

# Google Cloud Console → APIとサービス → 認証情報 → OAuthクライアントID(Webアプリ)
# リダイレクトURI:
#   http://localhost:3000/api/auth/callback/google
#   https://sol-player-web.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js のセッション暗号化キー。`openssl rand -base64 32` で生成
AUTH_SECRET=

# PostgreSQL接続文字列（Neon: https://neon.tech のダッシュボードからコピー）
# 例: postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
